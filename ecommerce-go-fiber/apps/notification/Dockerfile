FROM golang:1.26.1-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/notification ./apps/notification/cmd/

FROM alpine:3.20

WORKDIR /app

COPY --from=builder /bin/notification /app/notification

EXPOSE 4040

CMD ["/app/notification"]