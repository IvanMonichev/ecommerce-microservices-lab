    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/common": "*",
    "@repo/contracts": "*",
    "amqplib": "^0.10.9",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6"
  }
}
