{
  "name": "@services/products",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "prebuild": "npm run build --workspace=@repo/common && npm run build --workspace=@repo/contracts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/app.js",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@repo/common": "*",
    "@repo/contracts": "*",
    "express": "^5.2.1",
    "mongoose": "^9.2.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
