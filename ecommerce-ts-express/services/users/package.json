    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/common": "*",
    "@repo/contracts": "*",
    "express": "^5.2.1",
    "mongoose": "^9.2.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
