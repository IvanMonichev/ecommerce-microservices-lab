{
  "name": "@services/api-gateway",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "prebuild": "npm run build --workspace=@repo/common && npm run build --workspace=@repo/contracts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/common": "*",
    "@repo/contracts": "*",
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6"
  }
}
