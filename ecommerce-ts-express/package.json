{
  "name": "ecommerce-ts-express",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "build:common": "npm run build --workspace=@repo/common",
    "build:contracts": "npm run build --workspace=@repo/contracts",
    "build:api-gateway": "npm run build --workspace=@services/api-gateway",
    "build:notification": "npm run build --workspace=@services/notification",
    "build:orders": "npm run build --workspace=@services/orders",
    "build:products": "npm run build --workspace=@services/products",
    "build:users": "npm run build --workspace=@services/users",
    "build": "npm run build:common && npm run build:contracts && npm run build:api-gateway && npm run build:notification && npm run build:orders && npm run build:products && npm run build:users",
    "dev:api-gateway": "npm run dev --workspace=@services/api-gateway",
    "dev:notification": "npm run dev --workspace=@services/notification",
    "dev:orders": "npm run dev --workspace=@services/orders",
    "dev:products": "npm run dev --workspace=@services/products",
    "dev:users": "npm run dev --workspace=@services/users"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
